{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noImplicitAny": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"newLine": "lf",
		"noEmit": true
	},
	"include": ["src/**/*", "__tests__/**/*", "*.config.ts"],
	"exclude": ["./dist", "./node_modules", "./coverage"]
}
