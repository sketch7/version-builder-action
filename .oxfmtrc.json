{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": true,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "sortImports": {
    "groups": [
      ["side_effect", "builtin", "external"],
      ["parent", "sibling", "index"]
    ],
    "newlinesBetween": true
  },
  "ignorePatterns": ["dist/**", "coverage/**", "*.lock", "pnpm-lock.yaml"],
  "overrides": [
    {
      "files": ["**/*.json", "**/*.jsonc", "**/*.md"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
